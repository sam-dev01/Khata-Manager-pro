{
   "name": "khata-manager-pro",
   "version": "1.0.0",
   "homepage": "https://shop.kimiclaw.in/",
   "private": true,
   "main": "electron/main.js",
   "scripts": {
      "dev": "vite",
      "build": "vite build",
      "preview": "vite preview",
      "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
      "electron:build": "vite build && electron-builder",
      "dist": "npm run electron:build"
   },
   "dependencies": {
      "@ant-design/icons": "^5.2.5",
      "@google/generative-ai": "^0.24.1",
      "antd": "^5.8.0",
      "dayjs": "^1.11.9",
      "dexie": "^4.2.1",
      "dexie-react-hooks": "^4.2.0",
      "dompurify": "^3.4.5",
      "firebase": "^12.5.0",
      "html5-qrcode": "^2.3.8",
      "react": "^18.2.0",
      "react-barcode": "^1.6.1",
      "react-dom": "^18.2.0",
      "react-speech-recognition": "^3.10.0",
      "regenerator-runtime": "^0.14.1",
      "tesseract.js": "^7.0.0"
   },
   "devDependencies": {
      "@vitejs/plugin-react": "^4.0.3",
      "concurrently": "^9.2.1",
      "cross-env": "^10.1.0",
      "electron": "^39.2.7",
      "electron-builder": "^26.4.0",
      "vite": "^4.4.5",
      "wait-on": "^9.0.3"
   },
   "build": {
      "appId": "com.khatamanager.pro",
      "productName": "Khata Manager Pro",
      "files": [
         "dist/**/*",
         "electron/**/*"
      ],
      "directories": {
         "output": "release"
      },
      "win": {
         "target": [
            "nsis",
            "portable"
         ],
         "icon": "public/favicon.ico"
      }
   }
}
