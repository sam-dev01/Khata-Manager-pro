{
    "rules": {
        "users": {
            "$uid": {
                ".read": "$uid === auth.uid",
                ".write": "$uid === auth.uid"
            }
        },
        "firms": {
            "$firmId": {
                ".read": "root.child('firms').child($firmId).child('members').child(auth.uid).exists()",
                ".write": "root.child('firms').child($firmId).child('members').child(auth.uid).exists() || !data.exists()",
                "members": {
                    ".write": "root.child('firms').child($firmId).child('members').child(auth.uid).child('role').val() === 'owner' || !data.exists()"
                },
                "data": {
                    ".write": "root.child('firms').child($firmId).child('members').child(auth.uid).exists()"
                }
            }
        },
        "public_invoices": {
            "$publicId": {
                ".read": true,
                ".write": "auth != null && (!data.exists() || data.child('createdBy').val() === auth.uid)"
            }
        },
        "shops": {
            "$shopId": {
                ".read": "data.child('ownerId').val() === auth.uid",
                ".write": "auth != null && (!data.exists() || data.child('ownerId').val() === auth.uid)"
            }
        }
    }
}